<table width="100%" cellpadding="0" cellspacing="0" style="padding:14px 14px; background:#f8fafc;">
  <tr>
    <td style="font-size:12px; color:#475569; padding-bottom:8px;">
      <div style="font-weight:700; margin-bottom:6px;">Stay Connected</div>
      <div style="margin-bottom:8px;">
        <a href="{{facebook}}" style="text-decoration:none; margin-right:6px; background:{{companyPrimaryColor}}; color:#fff; padding:4px 8px; border-radius:4px; font-size:11px;">Facebook</a>
        <a href="{{linkedin}}" style="text-decoration:none; margin-right:6px; background:{{companyPrimaryColor}}; color:#fff; padding:4px 8px; border-radius:4px; font-size:11px;">LinkedIn</a>
        <a href="{{website}}" style="text-decoration:none; background:{{companyPrimaryColor}}; color:#fff; padding:4px 8px; border-radius:4px; font-size:11px;">Website</a>
      </div>
      <div style="font-size:11px; color:#94a3b8;">{{companyAddress}}</div>
    </td>
    <td align="right" style="font-size:11px; color:#94a3b8; vertical-align: middle;">
      <div>&copy; {{year}} {{companyName}}. All rights reserved.</div>
    </td>
  </tr>
</table>
