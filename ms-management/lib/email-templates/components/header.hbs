<table width="100%" cellpadding="0" cellspacing="0" style="background:{{companyPrimaryColor}}; padding:18px 14px;">
  <tr>
    <td align="left" style="vertical-align: top; width:60%; padding-bottom:8px;">
      <table cellpadding="0" cellspacing="0" width="100%">
        <tr>
          <td style="vertical-align: middle;">
            <div style="display:inline-block; vertical-align: middle;">
              <div style="background:#ffffff; color:{{companyPrimaryColor}}; font-weight:900; font-size:18px; padding:6px 10px; border-radius:6px; display:inline-block;">{{logoText}}</div>
            </div>
            <div style="display:inline-block; vertical-align: middle; margin-left:10px; color:#ffffff; font-weight:800; font-size:14px;">{{companyName}}</div>
          </td>
        </tr>
      </table>
    </td>
    <td align="right" style="color:#ffffff; font-size:12px; vertical-align: top; width:40%;">
      <div style="font-weight:700;">{{companyEmail}}</div>
      <div style="font-weight:600; margin-top:4px;">{{companyPhone}}</div>
    </td>
  </tr>
</table>
