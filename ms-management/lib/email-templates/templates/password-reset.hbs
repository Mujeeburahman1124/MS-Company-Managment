{{> header}}
<table width="100%" cellpadding="0" cellspacing="0" style="padding:20px;">
  <tr>
    <td>
      <h2>Password Reset Request</h2>
      <p>Hi {{recipientName}},</p>
      <p>We received a request to reset your password. Use the link below to proceed. This link expires in {{expiresIn}} minutes.</p>
      <p><a href="{{resetLink}}" style="background:{{companyPrimaryColor '#2563eb'}}; color:#fff; padding:10px 14px; border-radius:8px; text-decoration:none;">Reset Password</a></p>
    </td>
  </tr>
</table>
{{> footer}}
