{{> header}}
<table width="100%" cellpadding="0" cellspacing="0" style="padding:20px;">
  <tr>
    <td>
      <h2 style="font-size:18px; margin:0 0 8px 0;">Placement Confirmation</h2>
      <p>Dear {{recipientName}},</p>
      <p>Congratulations! You have been placed at <strong>{{companyName}}</strong> for the role of <strong>{{position}}</strong>.</p>
      <div style="background:#fff; padding:12px; border-radius:8px; border:1px solid #eefcf3;">
        <p>Start Date: {{startDate}}</p>
        <p>Salary: {{salary}}</p>
      </div>
    </td>
  </tr>
</table>
{{> footer}}
