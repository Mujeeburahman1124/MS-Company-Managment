{{> header}}
<table width="100%" cellpadding="0" cellspacing="0" style="padding:20px;">
  <tr>
    <td>
      <h2 style="font-size:18px; margin:0 0 8px 0;">Offer Letter</h2>
      <p>Dear {{recipientName}},</p>
      <p>We are pleased to offer you the position of <strong>{{position}}</strong> at {{companyName}}.</p>
      <div style="background:#fff; padding:12px; border-radius:8px; border:1px solid #e6f7ff;">
        <p>Salary: {{salary}}</p>
        <p>Joining Date: {{joiningDate}}</p>
      </div>
      <p>Please reply to accept the offer.</p>
    </td>
  </tr>
</table>
{{> footer}}
