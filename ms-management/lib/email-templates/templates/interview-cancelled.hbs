{{> header}}
<table width="100%" cellpadding="0" cellspacing="0" style="padding:20px;">
  <tr>
    <td>
      <h2 style="font-size:18px; margin:0 0 8px 0;">Interview Cancelled</h2>
      <p>Hi {{recipientName}},</p>
      <p>We regret to inform you that your interview scheduled on {{date}} for <strong>{{role}}</strong> has been cancelled.</p>
      <p>Reason: {{reason}}</p>
      <p>If you have questions, contact {{companyEmail}}.</p>
    </td>
  </tr>
</table>
{{> footer}}
