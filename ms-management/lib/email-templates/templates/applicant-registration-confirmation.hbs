{{> header}}
<table width="100%" cellpadding="0" cellspacing="0" style="padding:20px;">
  <tr>
    <td>
      <h2 style="margin:0 0 10px 0; font-size:18px; color:#0f172a;">Registration Confirmed</h2>
      <p style="color:#475569;">Dear {{recipientName}},</p>
      <p style="color:#475569;">Thank you for registering your application with {{companyName}}. Your application ID is <strong>{{applicationId}}</strong>.</p>
      <div style="margin:18px 0; background:#ffffff; border-radius:8px; padding:14px; border:1px solid #e6eef8;">
        <p style="margin:0; color:#1f2937;">Position(s): {{positions}}</p>
        <p style="margin:6px 0 0 0; color:#475569;">Tracking Code: {{applicationId}}</p>
      </div>
    </td>
  </tr>
</table>
{{> footer}}
